# Observatorio — kaikai + raylib showcase para astrónomos
#
# Tres demos en uno, conmutables con teclas:
#
#   N - N-body solar      Integración leapfrog de los planetas
#                         del sistema solar bajo gravedad real:
#                         las elipses, la precesión y los
#                         períodos relativos salen del cálculo,
#                         no de un coseno hardcodeado. La fórmula
#                         a = G * Σ Mⱼ * (rⱼ - rᵢ) / |rⱼ - rᵢ|³
#                         typechequea sólo porque las unidades
#                         cuadran:  G : m³/(kg·s²),  M : kg,
#                         r : m  ⇒  a : m/s².
#
#   H - Hertzsprung-Russell  Scatter T_eff (eje X, log invertido)
#                            vs luminosidad solar (eje Y, log).
#                            Cada estrella coloreada por su tipo
#                            espectral (O/B/A/F/G/K/M) — las
#                            ramas main-sequence, gigantes rojas
#                            y enanas blancas se identifican a
#                            simple vista. type Spectral con
#                            pattern matching para color y radio.
#
#   P - Paralaje estelar  Vista comparada Tierra-enero / Tierra-
#                         julio. Las estrellas cercanas se
#                         desplazan visiblemente entre las dos
#                         fechas; las lejanas no. La paralaje en
#                         arcsec sobre la base de 2 au da la
#                         distancia en parsecs (de ahí el nombre).
#                         UoM: Real<pc>, Real<arcsec>, plus el
#                         alias arcsec_per_au.
#
# Showcase de features de kaikai:
#
#   - Units of measure compuestas (m³/(kg·s²), au/days², L_sol,
#     K, pc, arcsec). Las fórmulas físicas typechequean por
#     dimensiones; cambiar G a unidades incompatibles es un
#     error de compilación.
#   - Sum types + match guards: Mode (selección), Spectral
#     (clasificación con bandas).
#   - Mutable + Ref (PR #265 / #277): los planetas mutan
#     positions/velocities; el modo activo es un Ref[Int].
#   - Pattern matching exhaustivo para clasificar y dispatchar
#     entre modos.
#
# Controles:
#   N    modo N-body
#   H    modo Hertzsprung-Russell
#   P    modo paralaje
#   SPACE pausa (sólo afecta N-body)
#   + / -  velocidad de simulación N-body
#   R    reset al estado inicial del modo activo
#   ESC  salir

import ffi.raylib
import loop

# ============================================================
#  1. ===== MODEL ===============================================
# ============================================================

# ----- units of measure -----

unit m
unit kg
unit s
unit au              # astronomical unit (= 1.495979e11 m)
unit days
unit yr
unit kelvin          # T_eff (Kelvin)
unit lsol            # solar luminosity (= 3.828e26 W)
unit pc              # parsec
unit arcsec

unit au_per_day  = au / days
unit au_per_day2 = au / (days * days)
unit km_per_s    = m / s              # we'll just call our axis "m/s" then scale display

# Fundamental constants in au-day-msun units (so the planetary
# integrator stays away from 1e30-magnitude numbers).
#
# G in SI is 6.674e-11 m³/(kg·s²). Converting to au/day with
# masses expressed in solar masses gives 2.959e-4. In other
# words: G_au_day_msun ≈ 4π²/(yr_in_days)², which is just
# Kepler's third law.
unit msun

unit g_unit = au * au * au / (msun * days * days)

const g_au_day : Real<g_unit> = 0.000295912208<au * au * au / (msun * days * days)>

# ----- mode discriminator -----

type Mode = NBody | HR | Parallax

const mode_nbody    : Int = 0
const mode_hr       : Int = 1
const mode_parallax : Int = 2

fn mode_of(i: Int) : Mode = match i {
  0 -> NBody
  1 -> HR
  _ -> Parallax
}

fn mode_label(m: Mode) : String = match m {
  NBody    -> "N-body solar"
  HR       -> "Hertzsprung-Russell"
  Parallax -> "Paralaje estelar"
}

# ----- spectral classification -----
#
# Stars classified by surface temperature: O is hottest blue,
# M is coolest red. Bands taken from Harvard's classical
# breakpoints in Kelvin.

type Spectral = O | B | A | F | G | K | M

fn class_of_temp(t: Real<kelvin>) : Spectral = match t {
  k if k >= 30000.0<kelvin> -> O
  k if k >= 10000.0<kelvin> -> B
  k if k >=  7500.0<kelvin> -> A
  k if k >=  6000.0<kelvin> -> F
  k if k >=  5200.0<kelvin> -> G
  k if k >=  3700.0<kelvin> -> K
  _                          -> M
}

fn class_color(s: Spectral) : Color = match s {
  O -> rgba(0x9bb0ffFF)   # blue-white
  B -> rgba(0xaabffeFF)   # blue
  A -> rgba(0xcad7ffFF)   # white
  F -> rgba(0xf8f7ffFF)   # yellow-white
  G -> rgba(0xfff4e8FF)   # yellow (Sun)
  K -> rgba(0xffd2a1FF)   # orange
  M -> rgba(0xffae5cFF)   # red
}

fn class_label(s: Spectral) : String = match s {
  O -> "O"
  B -> "B"
  A -> "A"
  F -> "F"
  G -> "G"
  K -> "K"
  M -> "M"
}

# Visual radius for HR / parallax dots, in pixels. Bigger and
# brighter means a "louder" star to the eye.
fn class_radius(s: Spectral) : Real = match s {
  O -> 7.0
  B -> 6.0
  A -> 5.5
  F -> 5.0
  G -> 5.0
  K -> 4.5
  M -> 4.0
}

# ============================================================
#  2. ===== STATE ===============================================
#
#  Three datasets, one per mode: (a) the solar-system bodies
#  (Sun + 8 planets) for the N-body integrator; (b) a catalog
#  of ~25 well-known stars for the HR diagram and the parallax
#  view (same catalog reused).
# ============================================================

# ----- N-body: sun + 8 planets -----
#
# Positions in au, velocities in au/day, masses in solar
# masses. Initial conditions are heliocentric — sun at origin,
# planets at perihelion-ish along +x with circular-velocity in
# +y. (Approximation: real ephemerides have inclination,
# eccentricity, and phase, but for the showcase the planets
# tracing visible elliptical-ish loops is what matters.)

const n_bodies : Int = 9

# Solar system seeds (au, au/day, msun). Mercury, Venus, Earth,
# Mars, Jupiter, Saturn, Uranus, Neptune.
fn seed_x(i: Int) : Real = {
  if i == 0      { 0.0 }
  else if i == 1 { 0.387 }
  else if i == 2 { 0.723 }
  else if i == 3 { 1.000 }
  else if i == 4 { 1.524 }
  else if i == 5 { 5.203 }
  else if i == 6 { 9.537 }
  else if i == 7 { 19.191 }
  else           { 30.069 }
}

# Circular orbital velocity at distance r from a 1-msun star:
#   v = sqrt(G/r)   in au/day
# We compute this once at seed time so the orbits stay roughly
# circular even with the leapfrog integrator's small drift.
fn seed_vy(i: Int) : Real / Ffi = {
  if i == 0 { 0.0 }
  else {
    let r = seed_x(i)
    let g_bare = g_au_day / 1.0<au * au * au / (msun * days * days)>
    let v = real_sqrt_approx(g_bare / r)
    v
  }
}

# Newton's iteration sqrt for our purposes — kaikai's stdlib
# real_sqrt sits behind a libm extern, but we already have
# raylib.sqrt available everywhere we need it.
fn real_sqrt_approx(x: Real) : Real / Ffi = raylib.sqrt(x)

fn body_mass(i: Int) : Real = {
  if i == 0      { 1.0 }              # Sun
  else if i == 1 { 1.66e-7 }          # Mercury
  else if i == 2 { 2.45e-6 }          # Venus
  else if i == 3 { 3.00e-6 }          # Earth
  else if i == 4 { 3.23e-7 }          # Mars
  else if i == 5 { 9.55e-4 }          # Jupiter
  else if i == 6 { 2.86e-4 }          # Saturn
  else if i == 7 { 4.37e-5 }          # Uranus
  else           { 5.15e-5 }          # Neptune
}

fn body_name(i: Int) : String = {
  if i == 0      { "Sol" }
  else if i == 1 { "Mercurio" }
  else if i == 2 { "Venus" }
  else if i == 3 { "Tierra" }
  else if i == 4 { "Marte" }
  else if i == 5 { "Jupiter" }
  else if i == 6 { "Saturno" }
  else if i == 7 { "Urano" }
  else           { "Neptuno" }
}

fn body_color(i: Int) : Color = {
  if i == 0      { rgba(0xffd166FF) }       # Sun
  else if i == 1 { rgba(0xb08968FF) }
  else if i == 2 { rgba(0xefcb68FF) }
  else if i == 3 { rgba(0x4ea1ffFF) }
  else if i == 4 { rgba(0xff6b6bFF) }
  else if i == 5 { rgba(0xfca311FF) }
  else if i == 6 { rgba(0xe0c590FF) }
  else           { rgba(0x90c8e0FF) }
}

# ----- N-body integrator: leapfrog (kick-drift-kick) -----
#
# Each step: half-kick velocities by current accel, drift
# positions by full timestep, recompute accel, half-kick
# velocities again. Conserves energy long-term much better than
# explicit Euler.

fn init_bodies(xs: Array[Real], ys: Array[Real],
               vxs: Array[Real], vys: Array[Real],
               ms: Array[Real]) : Unit / Ffi + Mutable = {
  init_loop(xs, ys, vxs, vys, ms, 0)
}

fn init_loop(xs: Array[Real], ys: Array[Real],
             vxs: Array[Real], vys: Array[Real],
             ms: Array[Real], i: Int) : Unit / Ffi + Mutable = {
  if i >= n_bodies { () }
  else {
    xs[i] := seed_x(i)
    ys[i] := 0.0
    vxs[i] := 0.0
    vys[i] := seed_vy(i)
    ms[i] := body_mass(i)
    init_loop(xs, ys, vxs, vys, ms, i + 1)
  }
}

# Compute (ax, ay) for body i by summing G*m_j*(r_j-r_i)/|...|^3
# over all j != i. Writes the result into single-element arrays
# `ax_out` / `ay_out` so the recursive accumulator stays clean.
fn accel(i: Int,
         xs: Array[Real], ys: Array[Real], ms: Array[Real],
         ax_out: Array[Real], ay_out: Array[Real]) : Unit / Mutable = {
  ax_out[0] := 0.0
  ay_out[0] := 0.0
  accel_loop(i, xs, ys, ms, ax_out, ay_out, 0)
}

fn accel_loop(i: Int,
              xs: Array[Real], ys: Array[Real], ms: Array[Real],
              ax_out: Array[Real], ay_out: Array[Real],
              j: Int) : Unit / Mutable = {
  if j >= n_bodies { () }
  else {
    if j == i {
      accel_loop(i, xs, ys, ms, ax_out, ay_out, j + 1)
    } else {
      let dx = xs[j] - xs[i]
      let dy = ys[j] - ys[i]
      let r2 = dx * dx + dy * dy
      let r3 = r2 * real_sqrt_approx_bare(r2)
      # G in au/day units, ms[j] in msun: a contribution is
      # G * m_j / r³ * (dx, dy).
      let g_bare = g_au_day / 1.0<au * au * au / (msun * days * days)>
      let f = g_bare * ms[j] / r3
      ax_out[0] := ax_out[0] + f * dx
      ay_out[0] := ay_out[0] + f * dy
      accel_loop(i, xs, ys, ms, ax_out, ay_out, j + 1)
    }
  }
}

fn real_sqrt_approx_bare(x: Real) : Real / Mutable = {
  # Babylonian. Two iterations from x/2 are enough for our
  # display precision and avoid taking an Ffi dependency on every
  # single accel pair.
  if x <= 0.0 { 0.0 }
  else {
    let y0 = x * 0.5 + 0.0001
    let y1 = (y0 + x / y0) * 0.5
    let y2 = (y1 + x / y1) * 0.5
    let y3 = (y2 + x / y2) * 0.5
    y3
  }
}

# One leapfrog step. dt is in days. Pre-allocated scratch
# arrays `ax`, `ay` carry the per-body accel.
fn leapfrog_step(xs: Array[Real], ys: Array[Real],
                 vxs: Array[Real], vys: Array[Real],
                 ms: Array[Real],
                 ax: Array[Real], ay: Array[Real],
                 dt: Real) : Unit / Mutable = {
  # First half-kick.
  half_kick_loop(vxs, vys, xs, ys, ms, ax, ay, dt, 0)
  # Drift.
  drift_loop(xs, ys, vxs, vys, dt, 0)
  # Second half-kick.
  half_kick_loop(vxs, vys, xs, ys, ms, ax, ay, dt, 0)
}

fn half_kick_loop(vxs: Array[Real], vys: Array[Real],
                  xs: Array[Real], ys: Array[Real], ms: Array[Real],
                  ax: Array[Real], ay: Array[Real],
                  dt: Real, i: Int) : Unit / Mutable = {
  if i >= n_bodies { () }
  else {
    let ax_cell = array_make(1, 0.0)
    let ay_cell = array_make(1, 0.0)
    accel(i, xs, ys, ms, ax_cell, ay_cell)
    vxs[i] := vxs[i] + 0.5 * dt * ax_cell[0]
    vys[i] := vys[i] + 0.5 * dt * ay_cell[0]
    half_kick_loop(vxs, vys, xs, ys, ms, ax, ay, dt, i + 1)
  }
}

fn drift_loop(xs: Array[Real], ys: Array[Real],
              vxs: Array[Real], vys: Array[Real],
              dt: Real, i: Int) : Unit / Mutable = {
  if i >= n_bodies { () }
  else {
    xs[i] := xs[i] + dt * vxs[i]
    ys[i] := ys[i] + dt * vys[i]
    drift_loop(xs, ys, vxs, vys, dt, i + 1)
  }
}

# ----- star catalog -----
#
# 25 well-known stars + the Sun. (T_eff in Kelvin, luminosity in
# Lsun, distance in parsecs.) Numbers are real; sources: Hipparcos
# / Gaia DR3 / Wikipedia for the nearby and famous stars.

const n_stars : Int = 25

fn star_name(i: Int) : String = {
  if i == 0       { "Sol" }
  else if i == 1  { "Sirio A" }
  else if i == 2  { "Sirio B" }
  else if i == 3  { "Vega" }
  else if i == 4  { "Arcturus" }
  else if i == 5  { "Betelgeuse" }
  else if i == 6  { "Rigel" }
  else if i == 7  { "Proxima" }
  else if i == 8  { "Alpha Cen A" }
  else if i == 9  { "Alpha Cen B" }
  else if i == 10 { "Aldebaran" }
  else if i == 11 { "Antares" }
  else if i == 12 { "Pollux" }
  else if i == 13 { "Capella" }
  else if i == 14 { "Procyon A" }
  else if i == 15 { "Altair" }
  else if i == 16 { "Spica" }
  else if i == 17 { "Deneb" }
  else if i == 18 { "Bellatrix" }
  else if i == 19 { "Polaris" }
  else if i == 20 { "Mira" }
  else if i == 21 { "Barnard" }
  else if i == 22 { "Wolf 359" }
  else if i == 23 { "Lalande 21185" }
  else            { "61 Cygni A" }
}

