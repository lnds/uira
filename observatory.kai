  else if i == 12 { 4666.0<kelvin> }
  else if i == 13 { 4970.0<kelvin> }
  else if i == 14 { 6530.0<kelvin> }
  else if i == 15 { 7700.0<kelvin> }
  else if i == 16 { 22400.0<kelvin> }
  else if i == 17 { 8525.0<kelvin> }
  else if i == 18 { 21800.0<kelvin> }
