# ============================================================
#  3. ===== VIEW ================================================
# ============================================================

const width  : Int = 1100
const height : Int = 700

const col_bg     : Color = rgba(0x06080cFF)
const col_panel  : Color = rgba(0x101620FF)
const col_text   : Color = rgba(0xeaedf3FF)
const col_dim    : Color = rgba(0x6b7382FF)
const col_accent : Color = rgba(0xfca311FF)
const col_grid   : Color = rgba(0x1a2030FF)

# ----- mode N-body view -----

const cx     : Real = 550.0
const cy     : Real = 380.0
# Pixels per au — log-ish so we can show inner planets and
# Jupiter+ at the same time without one or the other vanishing.
fn px_per_au(scale: Real) : Real = scale

fn draw_nbody(font: Int,
              xs: Array[Real], ys: Array[Real],
              ms: Array[Real],
              trails: Array[Real], head: Int,
              scale: Real, sim_days: Real) : Unit / Ffi = {
  let s = px_per_au(scale)

  # Trails (rings of past positions per body).
  draw_trails(trails, head, s)

  # Bodies.
  draw_bodies_loop(font, xs, ys, ms, s, 0)

  # HUD.
  raylib.draw_text_ex(font, "MODO  N-body solar (gravedad real, leapfrog Verlet)",
                   24, 18, 26, 1.0, col_text)
  raylib.draw_text_ex(font, "dia simulado:", 24, 60, 20, 1.0, col_dim)
  raylib.draw_text_ex(font, int_to_string(real_to_int(sim_days)), 180, 60, 20, 1.0, col_text)
  raylib.draw_text_ex(font, "escala (au -> px):", 320, 60, 20, 1.0, col_dim)
  raylib.draw_text_ex(font, real_to_string(scale), 510, 60, 20, 1.0, col_text)
}

fn draw_bodies_loop(font: Int,
                    xs: Array[Real], ys: Array[Real],
                    ms: Array[Real], s: Real, i: Int) : Unit / Ffi = {
  if i >= n_bodies { () }
  else {
    let x = cx + xs[i] * s
    let y = cy + ys[i] * s
    if i == 0 {
      raylib.draw_circle(real_to_int(x), real_to_int(y), 10.0, body_color(i))
    } else {
      let r = if ms[i] > 0.0001 { 5.0 } else { 3.5 }   # gas giants bigger
      raylib.draw_circle(real_to_int(x), real_to_int(y), r, body_color(i))
      raylib.draw_text_ex(font, body_name(i),
                       real_to_int(x) + 8, real_to_int(y) - 8, 16, 1.0, col_dim)
    }
    draw_bodies_loop(font, xs, ys, ms, s, i + 1)
  }
}

const trail_len : Int = 128

fn record_trails(trails: Array[Real],
                 xs: Array[Real], ys: Array[Real],
                 head_ref: Ref[Int]) : Unit / Mutable = {
  let h = @head_ref
  trail_record_loop(trails, xs, ys, h, 0)
  head_ref := (h + 1) % trail_len
}

fn trail_record_loop(trails: Array[Real],
                     xs: Array[Real], ys: Array[Real],
                     h: Int, i: Int) : Unit / Mutable = {
  if i >= n_bodies { () }
  else {
    let base = i * trail_len * 2
    trails[base + h * 2]     := xs[i]
    trails[base + h * 2 + 1] := ys[i]
    trail_record_loop(trails, xs, ys, h, i + 1)
  }
}

fn draw_trails(trails: Array[Real], head: Int, s: Real) : Unit / Ffi =
  trails_body_loop(trails, head, s, 1)   # skip Sun (i=0)

fn trails_body_loop(trails: Array[Real], head: Int, s: Real,
                    i: Int) : Unit / Ffi = {
  if i >= n_bodies { () }
  else {
    trail_seg_loop(trails, head, s, i, 0)
    trails_body_loop(trails, head, s, i + 1)
  }
}

fn trail_seg_loop(trails: Array[Real], head: Int, s: Real,
                  i: Int, k: Int) : Unit / Ffi = {
  if k >= trail_len - 1 { () }
  else {
    let base = i * trail_len * 2
    let off1 = (head + k) % trail_len
    let off2 = (head + k + 1) % trail_len
    let x1r = trails[base + off1 * 2]
    let y1r = trails[base + off1 * 2 + 1]
    let x2r = trails[base + off2 * 2]
    let y2r = trails[base + off2 * 2 + 1]
    if (x1r != 0.0 or y1r != 0.0) and (x2r != 0.0 or y2r != 0.0) {
      let x1 = cx + x1r * s
      let y1 = cy + y1r * s
      let x2 = cx + x2r * s
      let y2 = cy + y2r * s
      raylib.draw_line(real_to_int(x1), real_to_int(y1),
                       real_to_int(x2), real_to_int(y2), raylib.rgba(0x303040FF))
    }
    trail_seg_loop(trails, head, s, i, k + 1)
  }
}

# ----- mode HR view -----
#
# X axis: log10(T_eff) inverted (high temp left). Y axis:
# log10(L / L_sun). Both with grid lines and labels.

fn log10_approx(x: Real) : Real = {
  # ln(x)/ln(10), with ln from a coarse Taylor around the mean.
  # Good enough for axis placement.
  if x <= 0.0 { 0.0 - 99.0 }
  else { ln_approx(x) / 2.302585 }
}

fn ln_approx(x: Real) : Real = {
  # Reduce x = 2^k * m with m in [1,2), then ln x = k*ln2 + ln m.
  # ln m via two terms of (m-1) - (m-1)²/2 is enough for axes.
  let r = reduce_pow2(x, 0)
  let k = r / 1000000.0       # encoded above as k * 1e6 + m_minus_1
  let m_minus_1 = (r - k * 1000000.0) - 1.0
  k * 0.693147 + m_minus_1 - m_minus_1 * m_minus_1 * 0.5
}

# Encode (k, m) into one Real to avoid building a tuple. Hacky
# but the demo only needs axis labels.
fn reduce_pow2(x: Real, k: Int) : Real = {
  if x >= 2.0 { reduce_pow2(x * 0.5, k + 1) }
  else if x < 1.0 { reduce_pow2(x * 2.0, k - 1) }
  else { int_to_real(k) * 1000000.0 + x }
}

fn draw_hr(font: Int) : Unit / Ffi = {
  raylib.draw_text_ex(font, "MODO  Diagrama Hertzsprung-Russell",
                   24, 18, 26, 1.0, col_text)
  raylib.draw_text_ex(font, "eje X: temperatura (K) decreciente   eje Y: luminosidad (L_sol)",
                   24, 56, 18, 1.0, col_dim)

  # Plot area.
  let px_x = 110
  let px_y = 110
  let px_w = 880
  let px_h = 510
  raylib.draw_rectangle(px_x, px_y, px_w, px_h, col_panel)

  # Grid lines: temp at 30000, 10000, 7500, 6000, 5200, 3700.
  draw_hr_grid(font, px_x, px_y, px_w, px_h)

  # Plot the catalog.
  draw_hr_stars(font, px_x, px_y, px_w, px_h, 0)
}

# Map T_eff (K) to X. Inverted log scale: hot stars on the left.
# Domain: [2500, 35000] K ⇒ [px_x + px_w, px_x] (right to left).
fn temp_to_x(t: Real, px_x: Int, px_w: Int) : Int = {
  let lo = 2500.0
  let hi = 35000.0
  let lt = log10_approx(t)
  let llo = log10_approx(lo)
  let lhi = log10_approx(hi)
  let frac = (lt - llo) / (lhi - llo)
  # Inverted: high temp -> small frac complement -> left.
  let x = int_to_real(px_x) + (1.0 - frac) * int_to_real(px_w)
  real_to_int(x)
}

# Map L (Lsun) to Y. Domain: [1e-4, 1e6] ⇒ [px_y + px_h, px_y].
fn lum_to_y(l: Real, px_y: Int, px_h: Int) : Int = {
  let lo = 0.0001
  let hi = 1000000.0
  let ll = log10_approx(l)
  let llo = log10_approx(lo)
  let lhi = log10_approx(hi)
  let frac = (ll - llo) / (lhi - llo)
  let y = int_to_real(px_y) + (1.0 - frac) * int_to_real(px_h)
  real_to_int(y)
}

fn draw_hr_grid(font: Int, px_x: Int, px_y: Int, px_w: Int, px_h: Int) : Unit / Ffi = {
  # Temperature grid lines at the Harvard breakpoints.
  draw_temp_line(font, 30000.0, "30000K  O", px_x, px_y, px_w, px_h)
  draw_temp_line(font, 10000.0, "10000K  B", px_x, px_y, px_w, px_h)
  draw_temp_line(font,  7500.0,  "7500K  A", px_x, px_y, px_w, px_h)
  draw_temp_line(font,  6000.0,  "6000K  F", px_x, px_y, px_w, px_h)
  draw_temp_line(font,  5200.0,  "5200K  G", px_x, px_y, px_w, px_h)
  draw_temp_line(font,  3700.0,  "3700K  K", px_x, px_y, px_w, px_h)

  # Luminosity grid lines per decade.
  draw_lum_line(font, 0.0001, "1e-4 L", px_x, px_y, px_w, px_h)
  draw_lum_line(font, 0.01,   "1e-2 L", px_x, px_y, px_w, px_h)
  draw_lum_line(font, 1.0,    "  1  L", px_x, px_y, px_w, px_h)
  draw_lum_line(font, 100.0,  "100  L", px_x, px_y, px_w, px_h)
  draw_lum_line(font, 10000.0, "1e4 L", px_x, px_y, px_w, px_h)
  draw_lum_line(font, 1000000.0, "1e6 L", px_x, px_y, px_w, px_h)
}

fn draw_temp_line(font: Int, t: Real, label: String,
                  px_x: Int, px_y: Int, px_w: Int, px_h: Int) : Unit / Ffi = {
  let x = temp_to_x(t, px_x, px_w)
  raylib.draw_rectangle(x, px_y, 1, px_h, col_grid)
  raylib.draw_text_ex(font, label, x - 38, px_y + px_h + 6, 14, 1.0, col_dim)
}

fn draw_lum_line(font: Int, l: Real, label: String,
                 px_x: Int, px_y: Int, px_w: Int, px_h: Int) : Unit / Ffi = {
  let y = lum_to_y(l, px_y, px_h)
  raylib.draw_rectangle(px_x, y, px_w, 1, col_grid)
  raylib.draw_text_ex(font, label, px_x - 70, y - 8, 14, 1.0, col_dim)
}

fn draw_hr_stars(font: Int, px_x: Int, px_y: Int, px_w: Int, px_h: Int,
                 i: Int) : Unit / Ffi = {
  if i >= n_stars { () }
  else {
    let t = star_temp(i)
    let l = star_lum(i)
    let s = class_of_temp(t)
    let x = temp_to_x(t / 1.0<kelvin>, px_x, px_w)
    let y = lum_to_y(l / 1.0<lsol>,    px_y, px_h)
    raylib.draw_circle(x, y, class_radius(s), class_color(s))
    # Label only the famous ones to keep the plot legible.
    if i <= 6 or i == 11 or i == 17 {
      raylib.draw_text_ex(font, star_name(i), x + 10, y - 8, 16, 1.0, col_text)
    }
    draw_hr_stars(font, px_x, px_y, px_w, px_h, i + 1)
  }
}

# ----- mode parallax view -----
#
# Two side-by-side sky panels: the same star catalog as seen
# from Earth in January and from Earth in July (6 months apart,
# Earth has moved 2 au across the orbit). Nearby stars shift
# visibly between the two panels; far stars don't.

const pan_w  : Int = 510
const pan_h  : Int = 510
const pan_y  : Int = 120
const pan_lx : Int = 30
const pan_rx : Int = 560

# Project a star to a panel given the observer's `obs_x` (the
# x-coordinate in au of Earth at the observation moment, in
# heliocentric coords). The shift due to parallax is
# Δθ ≈ obs_x / d  (radians, small-angle).
#
# We project the unshifted RA/Dec into the panel first, then
# nudge by the parallax shift in the X axis.
fn project_star(font: Int, i: Int, obs_x: Real,
                panel_x: Int, panel_w: Int, panel_h: Int) : Unit / Ffi = {
  # Base (RA, Dec) in flat-sky coords. RA: [0,24h] -> [0, panel_w].
  let ra = star_ra_h(i)
  let dec = star_dec_deg(i)
  let base_x = int_to_real(panel_x) + ra / 24.0 * int_to_real(panel_w)
  let base_y = int_to_real(pan_y) + (90.0 - dec) / 180.0 * int_to_real(panel_h)

  # Parallax shift, scaled visually so it's visible. Real shift
  # for nearest stars is ~1 arcsec; we amplify by `parallax_gain`.
  let d_pc = star_distance(i) / 1.0<pc>
  let shift_arcsec = obs_x / d_pc * parallax_gain
  let shift_px = shift_arcsec * arcsec_to_px

  let x = real_to_int(base_x + shift_px)
  let y = real_to_int(base_y)

  let t = star_temp(i)
  let s = class_of_temp(t)
  raylib.draw_circle(x, y, class_radius(s), class_color(s))
  if i <= 9 or i == 21 or i == 22 {
    raylib.draw_text_ex(font, star_name(i), x + 8, y - 10, 13, 1.0, col_dim)
  }
}

const parallax_gain : Real = 80.0   # visual amplification
const arcsec_to_px  : Real = 1.0    # base scale

fn draw_parallax(font: Int) : Unit / Ffi = {
  raylib.draw_text_ex(font, "MODO  Paralaje estelar",
                   24, 18, 26, 1.0, col_text)
  raylib.draw_text_ex(font, "estrellas cercanas se desplazan entre enero y julio   |   base: 2 au   ganancia visual: 80x",
                   24, 56, 16, 1.0, col_dim)

  # Panels.
  raylib.draw_rectangle(pan_lx, pan_y, pan_w, pan_h, col_panel)
  raylib.draw_rectangle(pan_rx, pan_y, pan_w, pan_h, col_panel)
  raylib.draw_text_ex(font, "Enero  (Tierra a -1 au)", pan_lx + 8, pan_y - 26, 18, 1.0, col_text)
  raylib.draw_text_ex(font, "Julio  (Tierra a +1 au)", pan_rx + 8, pan_y - 26, 18, 1.0, col_text)

  # Stars in each panel.
  draw_parallax_loop(font, pan_lx, pan_w, pan_h, 0.0 - 1.0, 0)
  draw_parallax_loop(font, pan_rx, pan_w, pan_h,  1.0,      0)
}

fn draw_parallax_loop(font: Int, panel_x: Int, panel_w: Int, panel_h: Int,
                      obs_x: Real, i: Int) : Unit / Ffi = {
  if i >= n_stars { () }
  else {
    project_star(font, i, obs_x, panel_x, panel_w, panel_h)
    draw_parallax_loop(font, panel_x, panel_w, panel_h, obs_x, i + 1)
  }
}

# ----- footer -----

fn draw_footer(font: Int, active: Mode) : Unit / Ffi = {
  let y = height - 50
  raylib.draw_rectangle(0, y, width, 50, col_panel)
  raylib.draw_text_ex(font, "N  N-body     H  HR diagram     P  Paralaje     SPACE pausa     + -  velocidad     R reset     ESC salir",
                   24, y + 16, 17, 1.0, col_dim)
}

# ============================================================
#  ===== ORCHESTRATOR ===========================================
# ============================================================

const key_n     : Int = 78
const key_h     : Int = 72
const key_p     : Int = 80
const key_space : Int = 32
const key_plus  : Int = 61
const key_minus : Int = 45
const key_r     : Int = 82

fn frame_loop(font: Int,
              xs: Array[Real], ys: Array[Real],
              vxs: Array[Real], vys: Array[Real],
              ms: Array[Real],
              trails: Array[Real],
              ax: Array[Real], ay: Array[Real],
              trail_head: Ref[Int],
              mode_ref: Ref[Int],
              paused: Ref[Int],
              dt_ref: Ref[Real],
              sim_days: Ref[Real],
              scale: Ref[Real]) : Unit / Ffi + Mutable = {
  until { raylib.window_should_close() } {
    # ---- input ----
    if raylib.is_key_pressed(key_n) { mode_ref := mode_nbody }
    if raylib.is_key_pressed(key_h) { mode_ref := mode_hr }
    if raylib.is_key_pressed(key_p) { mode_ref := mode_parallax }
    if raylib.is_key_pressed(key_space) {
      paused := if @paused == 0 { 1 } else { 0 }
    }
    if raylib.is_key_pressed(key_plus)  { dt_ref := @dt_ref * 1.5 }
    if raylib.is_key_pressed(key_minus) { dt_ref := @dt_ref / 1.5 }
    if raylib.is_key_pressed(key_r) {
      reset_for_mode(mode_of(@mode_ref),
                     xs, ys, vxs, vys, ms,
                     sim_days, dt_ref, scale)
    } else { () }

    # ---- STATE: tick the active mode ----
    let m = mode_of(@mode_ref)
    if @paused == 0 {
      tick_mode(m, xs, ys, vxs, vys, ms, ax, ay,
                trails, trail_head, sim_days, dt_ref)
    } else { () }

    # ---- VIEW: render the active mode ----
    raylib.begin_drawing()
    raylib.clear_background(col_bg)
    render_mode(font, m, xs, ys, ms, trails, @trail_head, @scale, @sim_days)
    draw_footer(font, m)
    raylib.end_drawing()
  }
}

fn reset_for_mode(m: Mode,
                  xs: Array[Real], ys: Array[Real],
                  vxs: Array[Real], vys: Array[Real],
                  ms: Array[Real],
                  sim_days: Ref[Real], dt_ref: Ref[Real],
                  scale: Ref[Real]) : Unit / Ffi + Mutable = match m {
  NBody -> {
    init_bodies(xs, ys, vxs, vys, ms)
    sim_days := 0.0
    dt_ref := 1.0
    scale := 28.0
  }
  HR -> { () }
  Parallax -> { () }
}

fn tick_mode(m: Mode,
             xs: Array[Real], ys: Array[Real],
             vxs: Array[Real], vys: Array[Real],
             ms: Array[Real],
             ax: Array[Real], ay: Array[Real],
             trails: Array[Real],
             trail_head: Ref[Int],
             sim_days: Ref[Real],
             dt_ref: Ref[Real]) : Unit / Mutable = match m {
  NBody -> {
    leapfrog_step(xs, ys, vxs, vys, ms, ax, ay, @dt_ref)
    record_trails(trails, xs, ys, trail_head)
    sim_days := @sim_days + @dt_ref
  }
  HR -> { () }
  Parallax -> { () }
}

fn render_mode(font: Int, m: Mode,
               xs: Array[Real], ys: Array[Real], ms: Array[Real],
               trails: Array[Real], head: Int,
               scale: Real, sim_days: Real) : Unit / Ffi = match m {
  NBody    -> draw_nbody(font, xs, ys, ms, trails, head, scale, sim_days)
  HR       -> draw_hr(font)
  Parallax -> draw_parallax(font)
}

fn main() : Unit / Ffi + Mutable = {
  raylib.set_random_seed(42)

  # N-body state.
  let xs = array_make(n_bodies, 0.0)
  let ys = array_make(n_bodies, 0.0)
  let vxs = array_make(n_bodies, 0.0)
  let vys = array_make(n_bodies, 0.0)
  let ms = array_make(n_bodies, 0.0)
  let ax = array_make(n_bodies, 0.0)
  let ay = array_make(n_bodies, 0.0)
  let trails = array_make(n_bodies * trail_len * 2, 0.0)

  raylib.init_window(width, height, "Observatorio / kaikai + raylib")
  raylib.set_target_fps(60)

  # Load a smooth TTF at a generous pixel size so labels stay
  # crisp at the audience's distance. -1 means "fall back to the
  # bitmap default", which still works (less pretty).
  let font = raylib.load_font("/System/Library/Fonts/Supplemental/Arial.ttf", 32)

  init_bodies(xs, ys, vxs, vys, ms)

  let trail_head = Mutable.ref_make(0)
  let mode_ref   = Mutable.ref_make(mode_nbody)
  let paused     = Mutable.ref_make(0)
  let dt_ref     = Mutable.ref_make(1.0)        # 1 day per step initially
  let sim_days   = Mutable.ref_make(0.0)
  let scale      = Mutable.ref_make(28.0)       # px per au

  frame_loop(font, xs, ys, vxs, vys, ms,
             trails, ax, ay,
             trail_head, mode_ref, paused, dt_ref, sim_days, scale)
  raylib.unload_font(font)

  raylib.close_window()
}
